# Manolle AI shared environment template.
# Copy the frontend and backend examples into the correct app folders when running locally.

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Custom auth / admin
JWT_SECRET=replace_with_long_random_secret
ADMIN_USER_ID=admin
ADMIN_PASSWORD=replace_with_strong_admin_password

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx

# Vapi direct calling
VAPI_PRIVATE_KEY=your_vapi_private_api_key
VAPI_ASSISTANT_ID=your_vapi_assistant_id
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id
VAPI_WEBHOOK_SECRET=replace_with_long_random_secret

# Email
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Manolle AI <onboarding@manolle.ai>

# Backend
BACKEND_ALLOWED_ORIGINS=http://localhost:3000
